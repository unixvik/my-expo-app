####################################
# Root-level
####################################

# OS / Editor junk
.DS_Store
Thumbs.db
*.log

# IDEs
.idea/
.vscode/
*.swp
*.swo

####################################
# Node / JS (shared)
####################################

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

.env
.env.*
!.env.example

####################################
# Frontend — React + Vite
####################################

# Build output
frontend/dist/
frontend/.vite/

# Cache
frontend/node_modules/

# Testing
frontend/coverage/

####################################
# Backend — Colyseus (Node.js)
####################################

# Dependencies
backend/node_modules/

# Build output (if using TS or bundlers)
backend/dist/
backend/build/

# Runtime data
backend/.colyseus/
backend/logs/

# Testing
backend/coverage/

####################################
# TypeScript
####################################

*.tsbuildinfo

